{
  "name": "footory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:phase-a": "playwright test tests/e2e/phase-a",
    "test:e2e:scenarios": "playwright test tests/e2e/scenarios",
    "test:e2e:design": "playwright test tests/e2e/design",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auth:save": "mkdir -p .auth && playwright codegen --device=\"iPhone 15 Pro Max\" --save-storage=.auth/user.json http://localhost:3000/login",
    "test:e2e:auth": "E2E_AUTH_STATE=.auth/user.json playwright test",
    "test:qa": "npm run typecheck && npm run test:run && npm run test:e2e",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "firebase": "^12.10.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
